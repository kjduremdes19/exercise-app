# Copy this file to .env.local and fill in values from your Supabase project dashboard.
# Get these at: https://supabase.com/dashboard/project/<your-project>/settings/api

# Public (exposed to the browser — used by @supabase/ssr browser client)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only (NEVER import this from code under app/ or components/)
# Used by scripts/seed.ts to bypass RLS when seeding catalog data.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
